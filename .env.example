# .env.example — скопируйте в .env и заполните значения
# cp .env.example .env && vi .env

# ── Домены ──────────────────────────────────────────────────────────────
# Публичный домен для редиректора коротких ссылок
# (отображается в shlink-api и nginx виртуальном хосте)
DOMAIN_SHORT=shlink.example.com

# ── PostgreSQL ────────────────────────────────────────────────────────────
SHLINK_DB_NAME=shlink
SHLINK_DB_USER=shlink
SHLINK_DB_PASSWORD=change_me_db_password

# ── Shlink API ────────────────────────────────────────────────────────────
# Начальный admin API key (создаётся при первом старте)
ADMIN_SHLINK_API_KEY=change_me_admin_api_key

# ── Keycloak ──────────────────────────────────────────────────────────────
# FQDN Keycloak (если недоступен через DNS, oauth2-proxy резолвит через extra_hosts)
KEYCLOAK_HOST=keycloak.example.com
KEYCLOAK_IP=192.168.1.100

# ── oauth2-proxy ──────────────────────────────────────────────────────────
# Client secret из Keycloak → Clients → shlink-bff → Credentials
OAUTH2_CLIENT_SECRET_SHLINK=change_me_client_secret
# Случайная строка 32 байта: openssl rand -base64 32
OAUTH2_COOKIE_SECRET=change_me_cookie_secret_32bytes

# ── Фичи-флаги unified-backend ──────────────────────────────────────────
# Добавлять префикс пользователя к слагу URL
FEATURE_USER_SLUG_PREFIX=false
# Использовать внутренний ID тега вместо публичного имени
FEATURE_USER_TAG_INTERNAL_ID=false
